{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core permissions plus the native file dialog used to pick input/output files.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "notification:default",
    "opener:default",
    { "identifier": "opener:allow-open-path", "allow": [{ "path": "**" }] },
    { "identifier": "opener:allow-reveal-item-in-dir", "allow": [{ "path": "**" }] }
  ]
}
