{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sukoon",
  "version": "0.1.0",
  "identifier": "app.sukoon.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web"
  },
  "app": {
    "windows": [
      {
        "title": "Sukoon",
        "width": 480,
        "height": 680,
        "minWidth": 440,
        "minHeight": 600,
        "maxWidth": 560,
        "maxHeight": 820,
        "resizable": true,
        "center": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; media-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/sukoon-preview/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "appimage"],
    "shortDescription": "Remove background music, keep speech clear.",
    "longDescription": "Sukoon removes background music from videos and audio while preserving speech. On-device by default.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 185 },
        "applicationFolderPosition": { "x": 480, "y": 185 }
      }
    }
  }
}
