{
  "manifest_version": 3,
  "name": "Sukoon — Music Remover",
  "version": "0.1.0",
  "description": "Reduces instrumental background music while keeping speech and recitation clear — on YouTube, Facebook, Instagram, X, and any HTML5 video. On-device. Never blocks, skips, or mutes ads.",
  "minimum_chrome_version": "124",
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Sukoon",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["storage", "unlimitedStorage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-loader.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js", "assets/*", "worklet.js", "dfn_wasm_bg.wasm"],
      "matches": ["<all_urls>"]
    }
  ]
}
